# Copy to secrets.local.env (gitignored) and fill in your deploy values.
#   cp secrets.local.env.example secrets.local.env
# FUNCTION_URL is whichever endpoint you deployed:
#   function  -> https://functions.yandexcloud.net/YOUR_FUNCTION_ID
#   container -> https://YOUR_CONTAINER_ID.containers.yandexcloud.net
export FUNCTION_URL="https://functions.yandexcloud.net/YOUR_FUNCTION_ID"
export TOKEN="YOUR_TOKEN"
